  "fallback_answer_contract": {
    "sections": [
      "conclusion",
      "basis_with_citation",
      "next_step",
      "required_user_information",
      "human_or_authorized_service_escalation"
    ],
    "must_include": [
      "Use only legally approved published annotations for matched high-risk categories.",
      "Ask for missing model year, serial number, country/market, photos, or video when needed.",
      "State that final warranty approval, recall hit/miss, and safety inspection decisions require the rules service, an authorized service provider, or human/manual review."
    ],
    "must_not_include": [
      "Do not improvise repair steps for damaged batteries, brake failure, or frame cracks.",
      "Do not advise riding when a known safety fault is present.",
      "Do not claim final warranty approval or recall status from RAG text alone."
    ]
  }
