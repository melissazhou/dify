{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dify.local/schemas/bike-brand/ingestion_checklist.schema.json",
  "title": "Bike Brand P0 Ingestion Checklist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "last_updated",
    "blocking_policy",
    "checklist"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "blocking_policy": {
      "type": "string",
      "enum": [
        "all_blocking_checks_must_pass"
      ]
    },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "applies_to_domains",
          "blocking",
          "requirement",
          "evidence",
          "static_validation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^P0-KB-[0-9]{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "applies_to_domains": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "consumer_support",
                "product_catalog",
                "manuals_and_service",
                "warranty_policy",
                "dealer_internal",
                "safety_and_recall",
                "all"
              ]
            }
          },
          "blocking": {
            "type": "boolean"
          },
          "requirement": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "static_validation": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
