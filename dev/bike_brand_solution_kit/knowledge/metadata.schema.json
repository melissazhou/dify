{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dify.local/schemas/bike-brand/metadata.schema.json",
  "title": "Bike Brand Knowledge Metadata",
  "description": "Strict metadata contract for bicycle and e-bike knowledge chunks before ingestion into Dify knowledge bases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_document_id",
    "chunk_id",
    "knowledge_domain",
    "brand",
    "series",
    "model",
    "model_year",
    "language",
    "country",
    "market",
    "audience",
    "channel",
    "bike_type",
    "drive_system_vendor",
    "battery_model",
    "display_model",
    "component_vendor",
    "part_number",
    "document_type",
    "policy_type",
    "issue_category",
    "warranty_region",
    "effective_date",
    "valid_until",
    "version",
    "status",
    "risk_level",
    "legal_approved",
    "safety_related",
    "related_part_ids",
    "compatible_model_ids",
    "related_error_codes",
    "security_classification",
    "pii_redacted",
    "source_uri",
    "owner_team"
  ],
  "properties": {
    "source_document_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._:-]{2,127}$",
      "description": "Stable source document identifier from the governed content source."
    },
    "chunk_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._:-]{2,191}$",
      "description": "Stable chunk identifier, unique within the source document."
    },
    "knowledge_domain": {
      "type": "string",
      "enum": [
        "consumer_support",
        "product_catalog",
        "manuals_and_service",
        "warranty_policy",
        "dealer_internal",
        "safety_and_recall"
      ]
    },
    "brand": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "series": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "model": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "model_year": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1990,
      "maximum": 2100
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$",
      "description": "BCP 47 language tag such as en-US or zh-CN."
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code."
    },
    "market": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "audience": {
      "type": "string",
      "enum": [
        "consumer",
        "dealer",
        "internal",
        "support_agent",
        "sales",
        "service",
        "legal",
        "safety_quality"
      ]
    },
    "channel": {
      "type": "string",
      "enum": [
        "public-support",
        "web",
        "app",
        "dealer-portal",
        "contact-center",
        "internal-copilot",
        "sales-assist",
        "service-desk",
        "knowledge-ops"
      ]
    },
    "bike_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "bicycle",
        "e-bike",
        "cargo-bike",
        "road-bike",
        "mountain-bike",
        "city-bike",
        "gravel-bike",
        "folding-bike",
        "kids-bike",
        "accessory",
        "component",
        null
      ]
    },
    "drive_system_vendor": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "battery_model": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "display_model": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "component_vendor": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "part_number": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "document_type": {
      "type": "string",
      "enum": [
        "faq",
        "product_spec",
        "manual",
        "service_manual",
        "assembly_guide",
        "maintenance_guide",
        "error_code_reference",
        "warranty_policy",
        "return_policy",
        "shipping_policy",
        "safety_notice",
        "recall_notice",
        "service_bulletin",
        "dealer_sop",
        "training",
        "sales_playbook",
        "compatibility_note",
        "announcement"
      ]
    },
    "policy_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "warranty",
        "return_refund",
        "shipping",
        "payment",
        "financing",
        "privacy",
        "safety",
        "recall",
        "dealer_service",
        "none",
        null
      ]
    },
    "issue_category": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "pre_sales",
        "model_recommendation",
        "accessory_compatibility",
        "order_logistics",
        "return_refund",
        "warranty_claim",
        "troubleshooting",
        "battery_safety",
        "brake_safety",
        "frame_safety",
        "software_display",
        "dealer_service",
        "legal_complaint",
        "none",
        null
      ]
    },
    "warranty_region": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^([A-Z]{2}|[A-Z0-9-]{2,32})$"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "valid_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+(\\.[0-9]+){0,3}(-[A-Za-z0-9.-]+)?$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "legal_review",
        "published",
        "deprecated",
        "archived"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "critical"
      ]
    },
    "legal_approved": {
      "type": "boolean"
    },
    "safety_related": {
      "type": "boolean"
    },
    "related_part_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "uniqueItems": true
    },
    "compatible_model_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      },
      "uniqueItems": true
    },
    "related_error_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "uniqueItems": true
    },
    "security_classification": {
      "type": "string",
      "enum": [
        "public",
        "restricted",
        "confidential"
      ]
    },
    "pii_redacted": {
      "type": "boolean"
    },
    "source_uri": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri-reference"
    },
    "owner_team": {
      "type": "string",
      "enum": [
        "knowledge_ops",
        "product",
        "support",
        "service",
        "legal",
        "safety_quality",
        "dealer_ops",
        "sales"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "published"
          }
        }
      },
      "then": {
        "properties": {
          "pii_redacted": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "safety_related": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "legal_approved": {
            "const": true
          },
          "risk_level": {
            "enum": [
              "high",
              "critical"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "document_type": {
            "enum": [
              "safety_notice",
              "recall_notice"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "safety_related": {
            "const": true
          },
          "legal_approved": {
            "const": true
          },
          "risk_level": {
            "enum": [
              "high",
              "critical"
            ]
          },
          "knowledge_domain": {
            "const": "safety_and_recall"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "audience": {
            "enum": [
              "dealer",
              "internal",
              "service",
              "support_agent",
              "sales"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "security_classification": {
            "enum": [
              "restricted",
              "confidential"
            ]
          }
        }
      }
    }
  ]
}
