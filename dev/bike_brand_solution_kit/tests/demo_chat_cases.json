    {
      "id": "chat-001-pre-sales-fit-and-range",
      "title": "Pre-sales product fit question",
      "request": {
        "message": "I commute 12 miles each way with a few hills. Is the Urban E 500 a good fit and what range should I expect?",
        "intent_hint": "pre_sales",
        "client_trace_id": "trace-chat-001",
        "context": {
          "tenant_id": "example-bike",
          "channel": "product_detail_page",
          "product": {
            "sku": "URB-E-500-2025-M",
            "model": "Urban E 500",
            "model_year": 2025,
            "product_url": "https://brand.example.com/products/urb-e-500",
            "battery_model": "PowerPack 500",
            "drive_system_vendor": "Bosch"
          },
          "user": {
            "audience": "consumer",
            "anonymous_id": "anon-local-001",
            "consent_to_store_chat": true,
            "locale": "en-US"
          },
          "session": {
            "session_id": "sess-local-001",
            "page_url": "https://brand.example.com/products/urb-e-500"
          },
          "market": {
            "market": "north-america",
            "country": "US",
            "language": "en-US",
            "currency": "USD"
          }
        }
      },
      "expected": {
        "workflow": "consumer_support_chatflow",
        "intent": "pre_sales",
        "http_status": 200,
        "required_response_fields": ["answer", "citations", "next_actions", "escalation", "feedback", "server_trace_id"],
        "required_citation_source_types": ["knowledge_base", "manual"],
        "escalation_status": "not_needed",
        "forbidden_behaviors": ["state live price without a business API citation", "state live inventory without a business API citation"]
      }
    },
